{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/shim"
    },
    {
      "source": "/api/",
      "destination": "/api/shim?p="
    },
    {
      "source": "/api/(?!shim(?:/|$))(.*)",
      "destination": "/api/shim?p=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
