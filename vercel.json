{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix dashboard",
  "buildCommand": "npm run build --prefix dashboard",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/shim"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/shim?p=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
